# Nextcloud VM — COMPOSE-LEVEL env. Copy to .env and fill in.
# The real .env is gitignored and written at provision time. NEVER commit a real .env.
#
# WHO WRITES WHAT:
#   * The Ubuntu autoinstall (my.cloudhosting.lv/core/services.php) writes exactly ONE line:
#       NC_ADMIN_PASSWORD=<the same password the customer is emailed>
#   * firstboot.sh generates DB_PASSWORD, REDIS_PASSWORD and COLLABORA_ADMIN_PASSWORD on the
#     customer's own machine, and derives NC_DOMAIN. None of them exist anywhere else, so
#     there is nothing to leak from this repo or from a template.

# === Admin account (first start only) ===
# Read ONLY when the image installs itself against an empty volume. On every later start an
# installed Nextcloud ignores these. Changing the password here afterwards does NOTHING:
#   docker compose exec -u www-data app php occ user:resetpassword admin
NC_ADMIN_USER=admin
NC_ADMIN_PASSWORD=REPLACE_ME

# === Public host ===
# Leave BLANK to have firstboot.sh derive vps-<3rd octet>-<4th octet>.cloudhosting.lv from
# the primary IPv4 (the A record exists by convention and is what Let's Encrypt validates
# against over HTTP-01). Set it to override, e.g. when the customer brings their own domain:
# point their A record at this VM first, then set it here and `docker compose up -d`.
NC_DOMAIN=

# === Generated by firstboot.sh — do not set by hand ===
# DB_PASSWORD=
# REDIS_PASSWORD=
# COLLABORA_ADMIN_PASSWORD=

# === Tuning (optional) ===
# PHP_MEMORY_LIMIT=512M
# PHP_UPLOAD_LIMIT=10G
# Docker's default bridge pool. Nextcloud must trust the proxy in front of it, and Collabora
# must accept WOPI callbacks from it. Widen only if you move the compose networks.
# TRUSTED_PROXIES=172.16.0.0/12
# COLLABORA_ADMIN_USER=admin
